# Telegram (required)
TELEGRAM_BOT_TOKEN=

# MongoDB (optional but strongly recommended for persistence)
MONGODB_URI=

# External APIs (optional overrides)
# If missing, the bot uses safe public defaults.
PRICE_API_BASE_URL=
RAYDIUM_API_BASE_URL=

# Caching and polling intervals (optional)
CACHE_TTL_SECONDS=60
ALERT_POLL_INTERVAL_SECONDS=30
RAYDIUM_SCAN_INTERVAL_SECONDS=120

# Optional: limit how many pairs are shown in “Show Latest”
NEW_PAIRS_LATEST_LIMIT=15
